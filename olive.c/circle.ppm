          đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                     đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                            đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                