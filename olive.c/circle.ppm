       đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                         đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                   đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             đđđ                                                                                                                                                   đđđ                                                                                                                                       đđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                     đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                               đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      