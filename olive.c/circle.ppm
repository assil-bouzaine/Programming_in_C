                         đđđ                                                                                                                                 đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                               đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   đđđ                                                                                                                                                   đđđ                                                                                                                                 đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                         đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                   đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                